<script>
// All scripts copied from index.html for full functionality (loader, cursor, nav, particles, etc.)
// Initialize EmailJS (unused here)
emailjs.init("hnD6svOG9ul9LoBqK");

// loader 
// Hide loader after page fully loads
window.addEventListener("load", function() {
  const loader = document.getElementById('loader');
  setTimeout(() => {
      loader.style.opacity = '0';
      loader.style.transition = 'opacity 0.5s ease';
      setTimeout(() => loader.style.display = 'none', 500);
  }, 2000); // Show loader for only 2 seconds
});

// cursor
const dot = document.querySelector('.cursor-dot');
const ring = document.querySelector('.cursor-ring');
let mouse = { x: 0, y: 0 };
let ringPos = { x: 0, y: 0 };
const ease = 0.15;
document.addEventListener('mousemove', e => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
  dot.style.left = mouse.x + 'px';
  dot.style.top = mouse.y + 'px';
});
function animate() {
  ringPos.x += (mouse.x - ringPos.x) * ease;
  ringPos.y += (mouse.y - ringPos.y) * ease;
  ring.style.left = ringPos.x + 'px';
  ring.style.top = ringPos.y + 'px';
  requestAnimationFrame(animate);
}
animate();
const links = document.querySelectorAll('a, button');
links.forEach(link => {
  link.addEventListener('mouseenter', () => ring.classList.add('hover'));
  link.addEventListener('mouseleave', () => ring.classList.remove('hover'));
});

// NAV
window.addEventListener('scroll',()=>document.getElementById('mainNav').classList.toggle('scr',scrollY>60));
function closeMob(){document.getElementById('mobNav').classList.remove('open')}
document.getElementById('burger').addEventListener('click',function(){
  this.classList.toggle('open');
  document.getElementById('mobNav').classList.toggle('open');
});

// HERO LINES & PARTICLES (kept for hero consistency)
const hl=document.getElementById('heroLines');
hl.style.cssText='position:absolute;inset:0;display:flex;justify-content:space-between;pointer-events:none;z-index:1';
for(let i=0;i<12;i++){
  const s=document.createElement('span');
  s.style.cssText='display:block;width:1px;background:linear-gradient(180deg,transparent,rgba(0,212,255,.08) 30%,rgba(0,212,255,.08) 70%,transparent)';
  hl.appendChild(s);
}
const particlesContainer=document.getElementById('heroParticles');
for(let i=0;i<20;i++){
  const p=document.createElement('span');
  p.style.left=Math.random()*100+'%';
  p.style.animationDelay=Math.random()*15+'s';
  p.style.animationDuration=(10+Math.random()*10)+'s';
  particlesContainer.appendChild(p);
}

// SCROLL REVEAL
const obs=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){
      setTimeout(()=>e.target.classList.add('vis'),i*80);
      obs.unobserve(e.target);
    }
  });
},{threshold:.1,rootMargin:'0px 0px -34px 0px'});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));



// SMOOTH SCROLL
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const t=document.querySelector(a.getAttribute('href'));
    if(t){
      e.preventDefault();
      t.scrollIntoView({behavior:'smooth'});
    }
  });
});
